{
  "name": "@minhluudev/ai-tools",
  "version": "0.1.1",
  "description": "CLI to install AI skills from GitHub branches into Codex and Claude.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minhluudev/ai-tools.git"
  },
  "homepage": "https://github.com/minhluudev/ai-tools#readme",
  "bugs": {
    "url": "https://github.com/minhluudev/ai-tools/issues"
  },
  "bin": {
    "ai-tools": "dist/src/bin/ai-tools.js"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  },
  "aiTools": {
    "github": {
      "owner": "minhluudev",
      "repo": "ai-tools",
      "defaultBranch": "main",
      "skillsBranch": "skill-general",
      "manifestPath": "ai-tools.catalog.json",
      "excludeBranches": [
        "main",
        "master"
      ]
    }
  }
}
